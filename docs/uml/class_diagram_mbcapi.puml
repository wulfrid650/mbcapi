@startuml
title MBC API - Diagramme de classes metier consolide

hide empty methods
hide circle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

legend left
<<observed>> : directement observe dans le dump SQL ou les modeles
<<inferred>> : relation ou interpretation deduite du code applicatif
endlegend

package "Identite & acces" {
  class User <<observed>> {
    +id: bigint
    +name: string
    +email: string
    +role: enum
    +active_role_id: bigint?
    +employee_id: string?
    +phone: string?
    +is_active: bool
    +profile_completed: bool
    +company_name: string?
    +formation_id: bigint?
  }

  class Role <<observed>> {
    +id: bigint
    +slug: string
    +name: string
    +is_staff: bool
    +can_self_register: bool
  }

  class UserRole <<observed>> {
    +id: bigint
    +user_id: bigint
    +role_id: bigint
    +is_primary: bool
    +assigned_at: timestamp
    +metadata: json
  }

  class ActivityLog <<observed>> {
    +id: bigint
    +user_id: bigint?
    +action: string
    +description: text
    +subject_type: string?
    +subject_id: bigint?
    +created_at: timestamp
  }
}

package "Catalogue public & CRM" {
  class Service <<observed>> {
    +id: bigint
